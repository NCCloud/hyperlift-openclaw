# ──────────────────────────────────────────────
# OpenClaw Template — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ──────────────────────────────────────────────

OPENCLAW_DISABLE_BONJOUR=1
# AI provider API keys — set at least one.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
#if these 2 are correctly set, git-sync becomes enabled
WORKSPACE_GIT_TOKEN=
WORKSPACE_GIT_URL=

OPENCLAW_GATEWAY_PASSWORD=password123

OPENCLAW_PORT=80





