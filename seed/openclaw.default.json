{
  "gateway": {
    "mode": "local",
    "port": 3001,
    "bind": "lan",
    "auth": {
      "mode": "password"
    },
    "controlUi": {
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },

  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "openai/gpt-5.4"
      },
      "sandbox": {
        "mode": "off"
      }
    }
  },
  "update": {
    "checkOnStart": false
  },
  "discovery": {
    "mdns": {
      "mode": "off"
    }
  },
  "browser": {
    "enabled": false
  },
  "hooks": {
    "internal": {
      "entries": {
        "sync-status-inject": {
          "enabled": true
        },
        "bootstrap-extra-files": {
          "enabled": true,
          "paths": ["sync/AGENTS.md"]
        }
      }
    }
  }
}
